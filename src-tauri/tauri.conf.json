{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Naphwiki Timeline",
  "version": "0.2.0",
  "identifier": "com.naphwiki.timeline",
  "build": {
    "devUrl": "http://localhost:5173/timeline",
    "frontendDist": "https://www.naphwiki.com/timeline"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "create": false,
        "title": "Naphwiki Timeline",
        "width": 900,
        "height": 75,
        "minWidth": 320,
        "minHeight": 20,
        "decorations": false,
        "resizable": true,
        "alwaysOnTop": true,
        "transparent": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJCMjU2QjQzREUzQzBFMjkKUldRcERqemVRMnNsSzdzSU1FcmpqcjR4K1JKa3ZiSy9iY093TnZXSVFaNmdVOERQTU05TzRQWkgK",
      "endpoints": [
        "https://github.com/JoaLie/Naphwiki-Timeline/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
